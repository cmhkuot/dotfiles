[core]
	excludesfile = /Users/sondo/.global_gitignore
[user]
	name = Son Do
	email = hongson.do@ogilvy.com
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path =
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[commit]
	template = /Users/sondo/.stCommitMsg
[pull]
	rebase = true
[fetch]
	prune = true
[diff]
	colorMoved = zebra
